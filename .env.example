# Copy to .env and fill required values.

ADMIN_API_KEY=change-me-to-a-long-random-secret

# Frontend (optional, build-time): VITE_API_BASE only if API is on another origin than /ui.
# Leave unset or empty → browser uses same host/port as the page (auto). For local dev, see frontend/vite.config.ts proxy.
# VITE_API_BASE=https://api.example.com

# Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → copy token
TUNNEL_TOKEN=

# Host port for local debugging (tunnel uses http://gemini-api:9380 inside Docker)
GEMINI_API_PORT=4000

# Internal uvicorn port (tunnel route must use this port on host gemini-api)
# GEMINI_INTERNAL_PORT=9380

# Ring buffer size for GET /admin/api/logs (minimum 100)
# GEMINI_LOG_BUFFER_LINES=3000

# Optional: require X-Gemini-Api-Key on /v1/*
# GEMINI_API_CLIENT_KEY=

# Optional: outbound proxy for Google traffic (gemini_webapi.GeminiClient). Alias: GEMINI_PROXY.
#
# Full URL:
#   GEMINI_UPSTREAM_PROXY=http://127.0.0.1:7890
#   GEMINI_UPSTREAM_PROXY=socks5://user:pass@host:1080
#
# Or host:port:username:password (first three colons only; extra colons belong to the password):
#   GEMINI_UPSTREAM_PROXY=proxy.example.com:8080:myuser:mysecret
#   GEMINI_PROXY_SCHEME=http
# For SOCKS with the colon form use e.g. GEMINI_PROXY_SCHEME=socks5
# GEMINI_UPSTREAM_PROXY=
# GEMINI_PROXY_SCHEME=http

# Background cookie rotation (__Secure-1PSIDTS) via gemini_webapi (default: on)
# GEMINI_AUTO_ROTATE=true
# GEMINI_AUTO_REFRESH=true
# Interval in seconds; minimum 60 (library clamp)
# GEMINI_REFRESH_INTERVAL_SECONDS=600

# When X-Gemini-Profile header is omitted: profile id (default "default"), or "random" / "any" / "*" to pick a random profile with saved cookies
# GEMINI_V1_DEFAULT_PROFILE=default
#
# Per-request random profile (recommended for jobs): keep default above and send header:
#   X-Gemini-Profile: random
# (Response JSON includes "profile" so you know which account was used.)

# Redis (optional). docker-compose sets REDIS_URL=redis://redis:6379/0 by default for account-status cache + auxiliary JSON KV.
# Leave unset for local runs without Redis (account status falls back to per-profile account_status.json on disk).
# REDIS_URL=redis://127.0.0.1:6379/0
# GEMINI_REDIS_KEY_PREFIX=gemini
# Optional TTL (seconds) for account status keys in Redis only; 0 = no expiry
# GEMINI_REDIS_ACCOUNT_STATUS_TTL_SECONDS=0
