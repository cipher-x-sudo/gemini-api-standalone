# Copy to .env and fill all required values.

ADMIN_API_KEY=change-me-to-a-long-random-secret

# Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → copy token
TUNNEL_TOKEN=

# Existing Docker network that also has frontend / other services (docker network ls)
# Must exist before compose up (create your main stack first, or: docker network create portico_default)
DOCKER_NETWORK=portico_default

# Host port for local debugging (tunnel uses http://gemini-api:9380 inside Docker)
GEMINI_API_PORT=4000

# Internal uvicorn port inside the gemini-api container (tunnel route must use this port)
# GEMINI_INTERNAL_PORT=9380

# Optional: require X-Gemini-Api-Key on /v1/*
# GEMINI_API_CLIENT_KEY=
