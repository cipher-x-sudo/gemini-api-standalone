# Copy to .env and set a long random value for ADMIN_API_KEY.
ADMIN_API_KEY=change-me-to-a-long-random-secret
# Optional: require this header on /v1/* (defense in depth with Cloudflare Access)
# GEMINI_API_CLIENT_KEY=

# Host port published on the VPS (browser / Cloudflare tunnel target, e.g. http://127.0.0.1:4000)
GEMINI_API_PORT=4000
# Port uvicorn listens on *inside* the container (default 9380 — not 8080). Change if it clashes.
# GEMINI_INTERNAL_PORT=9380
