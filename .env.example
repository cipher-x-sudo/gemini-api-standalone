# Copy to .env and fill required values.

ADMIN_API_KEY=change-me-to-a-long-random-secret

# Frontend (optional): only if you build the SPA against a different API origin than where /ui is served.
# Docker/production default is same-origin (leave unset). For `npm run dev`, see frontend/vite.config.ts proxy.
# VITE_API_BASE=https://api.example.com

# Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → copy token
TUNNEL_TOKEN=

# Host port for local debugging (tunnel uses http://gemini-api:9380 inside Docker)
GEMINI_API_PORT=4000

# Internal uvicorn port (tunnel route must use this port on host gemini-api)
# GEMINI_INTERNAL_PORT=9380

# Optional: require X-Gemini-Api-Key on /v1/*
# GEMINI_API_CLIENT_KEY=

# Background cookie rotation (__Secure-1PSIDTS) via gemini_webapi (default: on)
# GEMINI_AUTO_ROTATE=true
# GEMINI_AUTO_REFRESH=true
# Interval in seconds; minimum 60 (library clamp)
# GEMINI_REFRESH_INTERVAL_SECONDS=600

# When X-Gemini-Profile header is omitted: profile id (default "default"), or "random" / "any" / "*" to pick a random profile with saved cookies
# GEMINI_V1_DEFAULT_PROFILE=default
#
# Per-request random profile (recommended for jobs): keep default above and send header:
#   X-Gemini-Profile: random
# (Response JSON includes "profile" so you know which account was used.)
